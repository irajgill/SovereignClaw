strict-peer-dependencies=false
auto-install-peers=true

# Auth for publishing @sovereignclaw/* packages is in `.npmrc.publish`.
# The publish workflow copies that file into `~/.npmrc` (or appends it to
# this one for the duration of the job) so `pnpm changeset publish` can
# authenticate. Keeping the auth line out of this committed `.npmrc`
# means pnpm install / lint / test runs don't emit the
# `Failed to replace env in config: ${NPM_TOKEN}` warning whenever
# `NPM_TOKEN` is unset (the common case in CI lint/test jobs and dev
# clones).
