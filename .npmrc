strict-peer-dependencies=false
auto-install-peers=true

# Auth for publishing @sovereignclaw/* packages. The `=${NPM_TOKEN:-}`
# default keeps `pnpm install` quiet when the env var is absent (CI / dev
# clones that don't publish). At publish time, set NPM_TOKEN in env and
# pnpm/npm interpolates it on the fly. The literal token is never written
# to disk by this file.
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
