{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "rootDir": "lib",
    "outDir": "lib",
    "noEmit": false,
    "incremental": false
  },
  "include": ["lib/codegen.ts", "lib/types.ts", "lib/validator.ts", "lib/seed-graph.ts"],
  "exclude": []
}
