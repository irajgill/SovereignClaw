    "ethers": "6.13.4",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reactflow": "11.11.4",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/node": "22.7.5",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "typescript": "5.6.3",
    "vitest": "2.1.2"
  }
}
