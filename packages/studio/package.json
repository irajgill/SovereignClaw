{
  "name": "@sovereignclaw/studio",
  "version": "0.0.0",
  "description": "ClawStudio — visual graph builder for SovereignClaw. Next.js app, not a library.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3030",
