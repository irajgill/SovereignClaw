// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateCode (pure function, snapshot-stable) > snapshots the seed graph output 1`] = `
"/**
 * Auto-generated by ClawStudio. Do not edit by hand.
 *
 * Nodes: 10, edges: 9.
 * Regenerate by re-exporting from ClawStudio or via the
 * \`generateCode(graph)\` pure function in @sovereignclaw/studio.
 */
import { config as loadDotenv } from 'dotenv';
loadDotenv();
import { JsonRpcProvider, Wallet } from 'ethers';

import { Agent, sealed0GInference } from '@sovereignclaw/core';
import { InMemory, OG_Log, deriveKekFromSigner, encrypted } from '@sovereignclaw/memory';
import { Mesh, planExecuteCritique } from '@sovereignclaw/mesh';

function required(name: string): string {
  const v = process.env[name];
  if (!v) throw new Error('missing env ' + name);
  return v;
}

async function main(): Promise<void> {
  const RPC_URL = required('RPC_URL');
  const INDEXER_URL = required('INDEXER_URL');
  const PRIVATE_KEY = required('PRIVATE_KEY');
  const ROUTER_URL = required('COMPUTE_ROUTER_BASE_URL');
  const ROUTER_KEY = required('COMPUTE_ROUTER_API_KEY');
  const MODEL_DEFAULT = process.env.COMPUTE_MODEL ?? 'qwen/qwen-2.5-7b-instruct';

  const provider = new JsonRpcProvider(RPC_URL);
  const signer = new Wallet(PRIVATE_KEY, provider);

  const memory_mem_critic_kek = await deriveKekFromSigner(signer, "studio-research-swarm-critic");
  const memory_mem_critic = encrypted(OG_Log({ namespace: "studio-research-swarm-critic", rpcUrl: RPC_URL, indexerUrl: INDEXER_URL, signer }), { kek: memory_mem_critic_kek });
  const memory_mem_executor_kek = await deriveKekFromSigner(signer, "studio-research-swarm-executor");
  const memory_mem_executor = encrypted(OG_Log({ namespace: "studio-research-swarm-executor", rpcUrl: RPC_URL, indexerUrl: INDEXER_URL, signer }), { kek: memory_mem_executor_kek });
  const memory_mem_planner_kek = await deriveKekFromSigner(signer, "studio-research-swarm-planner");
  const memory_mem_planner = encrypted(OG_Log({ namespace: "studio-research-swarm-planner", rpcUrl: RPC_URL, indexerUrl: INDEXER_URL, signer }), { kek: memory_mem_planner_kek });

  const inference_inf_critic = sealed0GInference({
    model: "qwen/qwen-2.5-7b-instruct",
    apiKey: ROUTER_KEY,
    baseUrl: ROUTER_URL,
    verifiable: true,
  });
  const inference_inf_executor = sealed0GInference({
    model: "qwen/qwen-2.5-7b-instruct",
    apiKey: ROUTER_KEY,
    baseUrl: ROUTER_URL,
    verifiable: true,
  });
  const inference_inf_planner = sealed0GInference({
    model: "qwen/qwen-2.5-7b-instruct",
    apiKey: ROUTER_KEY,
    baseUrl: ROUTER_URL,
    verifiable: true,
  });

  const agent_agent_critic = new Agent({
    role: "critic",
    systemPrompt: "You are a strict academic reviewer. Grade answers on factual accuracy against the rubric. Output a single-line JSON object only.",
    inference: inference_inf_critic,
    memory: memory_mem_critic,
  });
  const agent_agent_executor = new Agent({
    role: "executor",
    systemPrompt: "You are a careful researcher. Follow the plan step-by-step and produce a concise factual answer. Cite authors, years, and venue when relevant.",
    inference: inference_inf_executor,
    memory: memory_mem_executor,
  });
  const agent_agent_planner = new Agent({
    role: "planner",
    systemPrompt: "You decompose research questions into short, numbered plans. Each step is concrete and verifiable. Do not answer the question yourself — only plan.",
    inference: inference_inf_planner,
    memory: memory_mem_planner,
  });

  const mesh_mesh_swarm = new Mesh({
    meshId: "studio-research-swarm-v1",
    provider: InMemory({ namespace: "studio-research-swarm-v1-bus" }),
  });

  mesh_mesh_swarm.register(agent_agent_planner).register(agent_agent_critic);
  mesh_mesh_swarm.register(agent_agent_executor);

  const result = await planExecuteCritique({
    mesh: mesh_mesh_swarm,
    planner: agent_agent_planner,
    executors: [agent_agent_executor],
    critic: agent_agent_critic,
    task: "Name the 2017 paper that introduced the Transformer architecture, its first author, and its venue. One sentence per field.",
    maxRounds: 2,
    acceptThreshold: 0.7,
  });

  console.log('\\n=== mesh result ===');
  console.log(result.finalOutput);
  console.log('score:', result.score, 'rounds:', result.rounds);

  await Promise.all([agent_agent_critic.close(), agent_agent_executor.close(), agent_agent_planner.close()]);
  await mesh_mesh_swarm.close();
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
"
`;
