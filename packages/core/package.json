{
  "name": "@sovereignclaw/core",
  "version": "0.2.0",
  "description": "Agent runtime, inference adapter, and tool runtime for SovereignClaw.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amsorrytola/SovereignClaw.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/amsorrytola/SovereignClaw/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/amsorrytola/SovereignClaw/issues"
  },
  "keywords": [
    "0g",
    "ai",
    "agent",
    "sovereign",
    "inft",
    "erc-7857",
    "tee",
    "verifiable-inference"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sovereignclaw/memory": "workspace:*",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.7.5",
    "dotenv": "16.4.5",
    "tsup": "8.3.0",
    "typescript": "5.6.3",
    "vitest": "2.1.2"
  }
}
