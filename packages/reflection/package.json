{
  "name": "@sovereignclaw/reflection",
  "version": "0.1.1",
  "description": "Self-critique and learning persistence for SovereignClaw agents.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amsorrytola/SovereignClaw.git",
    "directory": "packages/reflection"
  },
  "homepage": "https://github.com/amsorrytola/SovereignClaw/tree/main/packages/reflection",
  "bugs": {
    "url": "https://github.com/amsorrytola/SovereignClaw/issues"
  },
  "keywords": [
    "0g",
    "agent",
    "reflection",
    "self-critique",
    "rubric"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@sovereignclaw/core": "workspace:*",
    "@sovereignclaw/memory": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.7.5",
    "dotenv": "16.4.5",
    "ethers": "6.13.4",
    "tsup": "8.3.0",
    "typescript": "5.6.3",
    "vitest": "2.1.2"
  },
  "peerDependencies": {
    "ethers": "^6.13.4"
  }
}
