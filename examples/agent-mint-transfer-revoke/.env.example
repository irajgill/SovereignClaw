# 0G Galileo Testnet
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
EXPLORER_URL=https://chainscan-galileo.0g.ai

# Alice and Bob both need to be funded testnet wallets.
# Fund at https://faucet.0g.ai (0.1 0G/day per wallet).
PRIVATE_KEY=0x_alice_replace_with_64_hex_chars
BOB_PRIVATE_KEY=0x_bob_replace_with_64_hex_chars

# Local dev oracle (apps/backend). Default port 8787.
ORACLE_URL=http://localhost:8787
# Optional bearer token; must match the backend's ORACLE_AUTH_TOKEN if set.
ORACLE_AUTH_TOKEN=

# Optional: route encrypted-memory KEK derivation through a stable namespace.
KEK_NAMESPACE=example-agent-mint-transfer-revoke

LOG_LEVEL=info
