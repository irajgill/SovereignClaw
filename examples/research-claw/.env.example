# 0G Galileo Testnet — chain endpoints (won't change unless 0G migrates)
RPC_URL=https://evmrpc-testnet.0g.ai
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
EXPLORER_URL=https://chainscan-galileo.0g.ai

# Funded testnet wallet — get 0.1 0G/day from https://faucet.0g.ai. NEVER
# commit a real key. The wallet pays storage + chain gas for this example.
PRIVATE_KEY=0x_replace_with_64_hex_chars

# 0G Compute Router (testnet). The Router has its own on-chain balance —
# your wallet's 0G is NOT auto-debited for inference. Visit
# https://pc.testnet.0g.ai, deposit testnet 0G, and create an API key.
COMPUTE_ROUTER_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
COMPUTE_ROUTER_API_KEY=replace_me

# Optional. Defaults to qwen/qwen-2.5-7b-instruct (TEE-verified, ~$0.07/M
# tokens). Any model in the Router catalog works.
COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# Optional. Separate KEK namespace per agent, so two agents on the same
# wallet don't share a key. Defaults to research-claw-v1.
KEK_NAMESPACE=research-claw-v1
