# Reuses the same 0G Galileo Testnet config as the smoke tests.
# In practice you'll just symlink or copy the repo-root .env.

RPC_URL=https://evmrpc-testnet.0g.ai
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
PRIVATE_KEY=0x_replace_with_funded_testnet_key

COMPUTE_ROUTER_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
COMPUTE_ROUTER_API_KEY=sk-replace_me

# IMPORTANT: this example uses two on-chain balances:
#   - wallet balance (faucet -> wallet) pays storage gas
#   - Router balance (wallet -> Router via pc.testnet.0g.ai) pays inference
# Both must be non-zero for this example to run end-to-end.
