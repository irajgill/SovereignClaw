mory"}],["$","$L2","/primitives/mesh",{"href":"/primitives/mesh","className":"rounded px-3 py-2 transition-colors bg-surface-2 text-text","children":"Mesh"}],["$","$L2","/primitives/inft",{"href":"/primitives/inft","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"iNFT"}],["$","$L2","/primitives/reflection",{"href":"/primitives/reflection","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Reflection"}],["$","$L2","/primitives/streaming",{"href":"/primitives/streaming","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Streaming"}],["$","$L2","/benchmarks",{"href":"/benchmarks","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Benchmarks"}],["$","$L2","/security",{"href":"/security","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Security"}],["$","$L2","/contracts",{"href":"/contracts","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Contracts"}]]}]}],["$","main",null,{"className":"flex-1 px-6 py-10 md:px-10","children":["$","article",null,{"className":"prose","children":[["$","h1","0",{"dangerouslySetInnerHTML":{"__html":"@sovereignclaw/mesh"}}],["$","p","1",{"dangerouslySetInnerHTML":{"__html":"Multi-agent coordination for SovereignClaw. One <strong>Bus</strong> (append-only event log over any <code>MemoryProvider</code>), one <strong>Mesh</strong> (Bus + agent registry), and <code>planExecuteCritique</code>, the default planner → executor → critic orchestration pattern. Everything the agents say to each other is a typed, sequenced, optionally-encrypted event on the log."}}],["$","h2","2",{"dangerouslySetInnerHTML":{"__html":"Install"}}],["$","pre","3",{"children":["$","code",null,{"children":"pnpm add @sovereignclaw/mesh @sovereignclaw/core @sovereignclaw/memory"}]}],["$","h2","4",{"dangerouslySetInnerHTML":{"__html":"10-line quickstart"}}],["$","pre","5",{"children":["$","code",null,{"children":"import { Agent, sealed0GInference } from '@sovereignclaw/core';\nimport { InMemory } from '@sovereignclaw/memory';\nimport { Mesh, planExecuteCritique } from '@sovereignclaw/mesh';\n\nconst inf = () =>\n  sealed0GInference({\n    /* model, apiKey, baseUrl, verifiable: true */\n  });\nconst mesh = new Mesh({ meshId: 'm1', provider: InMemory({ namespace: 'm1-bus' }) });\nmesh\n  .register(new Agent({ role: 'planner', systemPrompt: 'You plan.', inference: inf() }))\n  .register(new Agent({ role: 'executor', systemPrompt: 'You execute.', inference: inf() }))\n  .register(new Agent({ role: 'critic', systemPrompt: 'JSON only.', inference: inf() }));\nconst r = await planExecuteCritique({\n  mesh,\n  planner: mesh.get('planner')!,\n  executors: [mesh.get('executor')!],\n  critic: mesh.get('critic')!,\n  task: 'Name the Transformer authors. One sentence.',\n  maxRounds: 2,\n  acceptThreshold: 0.7,\n});"}]}],["$","h2","6",{"dangerouslySetInnerHTML":{"__html":"API"}}],["$","table","7",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Export"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Kind"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Purpose"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>Bus</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"class"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Append-only log: <code>append(event)</code>, <code>replay(fromSeq?)</code>, <code>on(handler)</code>. Thin wrapper on a <code>MemoryProvider</code>."}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>Mesh</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"class"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<code>Bus</code> + agent registry. <code>register / get / on / close</code>."}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>planExecuteCritique(opts)</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Planner → executor(s) → critic loop with acceptance threshold."}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>BusEvent&lt;P&gt;</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"type"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<code>{ type, fromAgent, seq, timestamp, parentSeq?, meshId, payload }</code>."}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>BusEventTypes</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"enum"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<code>TaskCreated / PlanCreated / ExecutionStarted / ExecutionComplete / CritiqueCreated / TaskComplete</code>."}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>SeqCounter</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"class"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Monotonic sequence generator. Used by <code>Bus</code> internally."}}]]}],["$","tr","6",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>eventKey / seqFromKey</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Canonical, lex-sortable key encoding for bus events."}}]]}]]}]]}],["$","h2","8",{"dangerouslySetInnerHTML":{"__html":"Errors"}}],["$","p","9",{"dangerouslySetInnerHTML":{"__html":"All extend <code>MeshError</code>:"}}],["$","table","10",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Error"}}],["$","th","1",{"dangerousl