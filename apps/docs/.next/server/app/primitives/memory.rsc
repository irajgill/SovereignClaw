__html":"10-line quickstart"}}],["$","pre","5",{"children":["$","code",null,{"children":"import { JsonRpcProvider, Wallet } from 'ethers';\nimport { OG_Log, encrypted, deriveKekFromSigner } from '@sovereignclaw/memory';\n\nconst signer = new Wallet(process.env.PRIVATE_KEY!, new JsonRpcProvider(process.env.RPC_URL!));\nconst kek = await deriveKekFromSigner(signer, 'my-agent');\nconst memory = encrypted(\n  OG_Log({\n    namespace: 'my-agent',\n    rpcUrl: process.env.RPC_URL!,\n    indexerUrl: process.env.INDEXER_URL!,\n    signer,\n  }),\n  { kek },\n);\nawait memory.set('greeting', new TextEncoder().encode('hello from sovereignclaw'));\nconst value = await memory.get('greeting'); // plaintext Uint8Array; ciphertext on the log"}]}],["$","h2","6",{"dangerouslySetInnerHTML":{"__html":"API"}}],["$","table","7",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Export"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Kind"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Purpose"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>MemoryProvider</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"interface"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<code>get / set / delete / list / flush / close</code> over keyed byte values."}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>InMemory(opts)</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"adapter"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Process-local backend. Namespaced. Used by tests and coordination."}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>OG_Log(opts)</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"adapter"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"0G Storage Log backend. Writes envelopes; keeps a pointer tree."}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>encrypted(provider, opts)</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"wrapper"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"AES-256-GCM around any provider. KEK in, keys/ciphertext out."}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>deriveKekFromSigner</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"EIP-191 sign a namespaced message, keccak256 → 32-byte KEK."}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>encryptValue / decryptValue</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Lower-level GCM helpers with AAD binding."}}]]}],["$","tr","6",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>buildAad</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Builds the canonical AAD for a (namespace, key, version) tuple."}}]]}],["$","tr","7",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>TOMBSTONE / isTombstone</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"const/fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Delete marker sentinel for append-only stores."}}]]}],["$","tr","8",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>readEnvelopeByRoot</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Low-level: read a single envelope by its 0G root hash."}}]]}]]}]]}],["$","h2","8",{"dangerouslySetInnerHTML":{"__html":"Errors"}}],["$","p","9",{"dangerouslySetInnerHTML":{"__html":"All typed; all extend <code>MemoryError</code>:"}}],["$","table","10",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Error"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"When"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>DecryptionError</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Envelope failed to decrypt (wrong KEK, wrong AAD, corrupt data)."}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>TamperingDetectedError</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"GCM tag mismatch — the envelope was tampered with in transit."}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>MalformedCiphertextError</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Envelope header didn’t match the expected v1 layout."}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>StorageError</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Backend rejected a read/write for a non-SDK reason."}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>StorageSdkError</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"0G SDK threw or the indexer returned a transient fee/node error."}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>InvalidKeyError</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"KEK is not 32 bytes / AAD is malformed."}}]]}],["$","tr","6",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>KeyDerivationError</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<code>deriveKekFromSigner</code> failed (usually the signer refused)."}}]]}],["$","tr","7",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>ProviderClosedError</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Operation after