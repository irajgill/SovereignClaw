ABIs from <code>contracts/out/</code>. Run <code>forge build</code> in <code>contracts/</code> once before building this package — the quickstart covers this."}}],["$","h2","5",{"dangerouslySetInnerHTML":{"__html":"10-line quickstart"}}],["$","pre","6",{"children":["$","code",null,{"children":"import { Wallet, JsonRpcProvider, randomBytes } from 'ethers';\nimport { loadDeployment, mintAgentNFT, revokeMemory, OracleClient } from '@sovereignclaw/inft';\n\nconst signer = new Wallet(process.env.PRIVATE_KEY!, new JsonRpcProvider(process.env.RPC_URL!));\nconst deployment = loadDeployment();\nconst oracle = new OracleClient({ url: 'http://localhost:8787' });\n\nconst minted = await mintAgentNFT({\n  agent: { role: 'researcher', getPointer: () => process.env.MEMORY_POINTER! },\n  owner: signer,\n  wrappedDEK: randomBytes(32),\n  deployment,\n});\nawait revokeMemory({ tokenId: minted.tokenId, owner: signer, oracle, deployment });"}]}],["$","h2","7",{"dangerouslySetInnerHTML":{"__html":"API"}}],["$","table","8",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Export"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Kind"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Purpose"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>mintAgentNFT</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Mints one iNFT. Commits pointer + wrappedDEK + metadata hash."}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>transferAgentNFT</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Transfers via oracle re-encryption; updates wrappedDEK atomically."}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>revokeMemory</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Owner signs → oracle registry → chain revoke. Irreversible."}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>recordUsage</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Append a typed usage record for downstream analytics."}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>OracleClient</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"class"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"HTTP client for <code>/oracle/{pubkey,reencrypt,revoke,prove,healthz}</code>."}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>loadDeployment</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Reads <code>deployments/0g-testnet.json</code>. Throws if missing."}}]]}],["$","tr","6",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>AgentNFTAbi / MemoryRevocationAbi</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"const"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Ethers-v6-compatible ABIs. Used internally; exposed for callers."}}]]}],["$","tr","7",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>explorerTxUrl / explorerAddressUrl</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"Format chainscan links for mint/transfer/revoke receipts."}}]]}],["$","tr","8",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>digestForOracleProof</code> etc."}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"fn"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"EIP-712 helpers — used by the oracle; exposed for audit tests."}}]]}],["$"