ext-text","children":"Memory"}],["$","$L2","/primitives/mesh",{"href":"/primitives/mesh","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Mesh"}],["$","$L2","/primitives/inft",{"href":"/primitives/inft","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"iNFT"}],["$","$L2","/primitives/reflection",{"href":"/primitives/reflection","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Reflection"}],["$","$L2","/primitives/streaming",{"href":"/primitives/streaming","className":"rounded px-3 py-2 transition-colors bg-surface-2 text-text","children":"Streaming"}],["$","$L2","/benchmarks",{"href":"/benchmarks","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Benchmarks"}],["$","$L2","/security",{"href":"/security","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Security"}],["$","$L2","/contracts",{"href":"/contracts","className":"rounded px-3 py-2 transition-colors text-muted hover:bg-surface hover:text-text","children":"Contracts"}]]}]}],["$","main",null,{"className":"flex-1 px-6 py-10 md:px-10","children":["$","article",null,{"className":"prose","children":[["$","h1","0",{"dangerouslySetInnerHTML":{"__html":"Streaming in <code>@sovereignclaw/core</code> and <code>@sovereignclaw/mesh</code> (v0.2.0)"}}],["$","p","1",{"dangerouslySetInnerHTML":{"__html":"Phase B added streaming SSE support to the core inference adapter and a unified <code>MeshEvent</code> surface to the mesh package. The motivation, the wire format, the public API, and the caveats are below."}}],["$","h2","2",{"dangerouslySetInnerHTML":{"__html":"Why streaming"}}],["$","p","3",{"dangerouslySetInnerHTML":{"__html":"The IncomeClaw demo UX (see <code>IncomeClaw-Roadmap.md</code> §1.5) shows agent \"thinking\" tokens as they arrive, not as a final blob. That single feature turns a 30 s wall-of-silence into a live thread the user can read along with — same model, same time-to-final-answer, dramatically different perceived latency. Without streaming, the framework is correct but the demo is dead air."}}],["$","p","4",{"dangerouslySetInnerHTML":{"__html":"Streaming is also a prerequisite for any frontend that wants to render mid-run state: tool-call chips, partial reasoning traces, \"agent is thinking...\" indicators. Phase B makes those primitives real instead of something the IncomeClaw side has to invent."}}],["$","h2","5",{"dangerouslySetInnerHTML":{"__html":"0G Compute Router SSE wire format (pinned)"}}],["$","p","6",{"dangerouslySetInnerHTML":{"__html":"Each event is a <code>data: &lt;JSON&gt;\\n\\n</code> line. The format observed live during Phase B kickoff (curl + <code>qwen/qwen-2.5-7b-instruct</code>) and frozen as the parser's input contract:"}}],["$","pre","7",{"children":["$","code",null,{"children":"$3"}]}],["$","p","8",{"dangerouslySetInnerHTML":{"__html":"Frame taxonomy the parser implements:"}}],["$","ol","9",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Role-handshake frame</strong> — first frame, empty <code>delta.content</code> plus"}}]]}],["$","p","10",{"dangerouslySetInnerHTML":{"__html":"   <code>role:\"assistant\"</code>. Emit nothing token-side."}}],["$","ol","11",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Delta-content frames</strong> — <code>delta.content</code> carries arbitrary text"}}]]}],["$","p","12",{"dangerouslySetInnerHTML":{"__html":"   (often <strong>multi-token</strong>, e.g. <code>\"\\nThree\\nFour\"</code> is one frame). Emit a    <code>'token'</code> chunk only when the string is non-empty."}}],["$","ol","13",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Stop frame</strong> — <code>finish_reason: \"stop\"</code>, empty <code>delta.content</code>. Emit"}}]]}],["$","p","14",{"dangerouslySetInnerHTML":{"__html":"   nothing."}}],["$","ol","15",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Usage-only frame</strong> — <code>choices: []</code>, <code>usage: { prompt_tokens, ... }</code>."}}]]}],["$","p","16",{"dangerouslySetInnerHTML":{"__html":"   Capture for the final <code>'done'</code> chunk."}}],["$","ol","17",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Attestation frame</strong> — top-level <code>x_0g_trace</code> object, no <code>choices</code>."}}]]}],["$","p","18",{"dangerouslySetInnerHTML":{"__html":"   Capture <code>tee_verified</code>, <code>provider</code>, <code>request_id</code>, and <code>billing</code> for the    final <code>'done'</code> chunk."}}],["$","ol","19",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Terminal sentinel</strong> — <code>data: [DONE]</code>. End of stream; close the"}}]]}],["$","p","20",{"dangerouslySetInnerHTML":{"__html":"   iterator after emitting <code>'done'</code>."}}],["$","p","21",{"dangerouslySetInnerHTML":{"__html":"<strong><code>tee_verified</code> IS present in streaming responses.</strong> Phase B confirmed it lives in the dedicated attestation frame (frame 5 above), not on the delta frames. The streaming <code>InferenceResult.attestation.teeVerified</code> matches the non-streaming value byte-for-byte."}}],["$","h2","22",{"dangerouslySetInnerHTML":{"__html":"<code>@sovereignclaw/core</code> streaming API"}}],["$","pre","23",{"children":["$","code",null,{"children":"import {\n  Agent,\n  sealed0GInference,\n  type InferenceChunk,\n  StreamInterruptedError,\n} from '@sovereignclaw/core';\n\nconst adapter = sealed0GInference({\n  model: 'qwen/qwen-2.5-7b-instruct',\n  apiKey: process.env.COMPUTE_ROUTER_API_KEY!,\n  verifiable: true,\n});\n\n// Direct adapter usage:\nconst result = await adapter.run([{ role: 'user', content: 'count to five' }], {\n  stream: true,\n  onChunk(chunk: InferenceChunk) {\n    if (chunk.type === 'token') process.stdout.write(chunk.text);\n    else if (chunk.type === 'done') console.log('\\n[done]', chunk.usage);\n  },\n});\nconsole.log(result.text); // full text\nconsole.log(result.attestation.teeVerified); // true|false|null\n\n// Or via Agent (the typical path):\nconst agent = new Agent({ role: 'researcher', inference: adapter });\nagent.on('agent.thinking.token', ({ text }) => process.stdout.write(text));\nagent.on('agent.thinking.end', ({ fullText }) => console.log('\\n', fullText));\nawait agent.run('count to five', { onChunk: () => undefined });"}]}],["$","p","24",{"dangerouslySetInnerHTML":{"__html":"Notes:"}}],["$","ul","25",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<code>onChunk</code> is the only \"stream this\" switch. The rest of the"}}]]}],["$","p","26",{"dangerouslySetInnerHTML":{"__html":"  <code>InferenceResult</code> shape is unchanged from the non-streaming path —   callers that ignore <code>onChunk</code> get the same shape they got in v0.1.x."}}],["$","ul","27",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"The promise still resolves to the full <code>InferenceResult</code> after the"}}]]}],["$","p","28",{"dangerouslySetInnerHTML":{"__html":"  stream completes. Don't try to parallelize \"consume chunks\" with   \"await the result\" — they happen in lockstep."}}],["$","ul","29",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<code>StreamInterruptedError</code> is thrown if the stream is malformed,"}}]]}],["$","p","30",{"dangerouslySetInnerHTML":{"__html":"  truncated mid-stream, or the <code>onChunk</code> callback throws. <strong>Mid-stream   retries are not attempted</strong> — partial state would corrupt the consumer.   The adapter retries only before the first byte is received (network   failures, 5xx). Callers who want to resume must restart the request."}}],["$","ul","31",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<code>timeoutMs</code> applies to the <strong>connection</strong> (first byte), not to the full"}}]]}],["$","p","32",{"dangerouslySetInnerHTML":{"__html":"  stream duration. A long model response will not accidentally expire.   For an explicit total-stream cap, supply your own <code>signal:</code> and clear   it via your own timer."}}],["$","ul","33",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<code>verify_tee: true</code> is sent on every streaming request when"}}]]}],["$","p","34",{"dangerouslySetInnerHTML":{"__html":"  <code>verifiable: true</code> is set on <code>sealed0GInference</code> (default)."}}],["$","h2","35",{"dangerouslySetInnerHTML":{"__html":"<code>@sovereignclaw/mesh</code> event surface"}}],["$","pre","36",{"children":["$","code",null,{"children":"$4"}]}],["$","p","37",{"dangerouslySetInnerHTML":{"__html":"<code>mesh.onEvent</code> is <strong>separate</strong> from <code>mesh.on</code> — that latter still subscribes to the durable bus log (the same source IncomeClaw will use for audit/replay). <code>onEvent</code> is the streaming surface for live UI consumption; <code>on</code> is for durability."}}],["$","p","38",{"dangerouslySetInnerHTML":{"__html":"<code>mesh.dispatch(input, pattern)</code> is what threads the <code>taskId</code>. Agent events emitted <strong>outside</strong> a <code>dispatch</code> call do not surface as <code>MeshEvent</code>s — by design, so callers can run agents directly without polluting the orchestrator's stream."}}],["$","h2","39",{"dangerouslySetInnerHTML":{"__html":"Caveats"}}],["$","ul","40",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong><code>onEvent</code> is ephemeral.</strong> Subscribers that disconnect miss whatever"}}]]}],["$","p","41",{"dangerouslySetInnerHTML":{"__html":"  fires while they are gone. The 0G Log bus (<code>mesh.bus</code>) is the durable   layer for replay/audit. Don't try to reconstruct UI state from   <code>onEvent</code> alone — read the bus on reconnect."}}],["$","ul","42",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Node 22 single-thread assumption.</strong> The mesh's <code>AsyncLocalStorage</code>"}}]]}],["$","p","43",{"dangerouslySetInnerHTML":{"__html":"  context that threads <code>taskId</code> through agent events relies on Node's   single-threaded async hooks. Worker-thread agents would need explicit   taskId propagation; we don't do that today."}}],["$","ul","44",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong><code>timeoutMs</code> applies to the connection, not full stream duration.</strong>"}}]]}],["$","p","45",{"dangerouslySetInnerHTML":{"__html":"  See above. If you want a total cap, use <code>signal:</code> and your own timer."}}],["$","ul","46",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>No mid-stream retries.</strong> A network blip after the first chunk"}}]]}],["$","p","47",{"dangerouslySetInnerHTML":{"__html":"  arrives is final — the adapter throws <code>StreamInterruptedError</code> and the   caller restarts."}}],["$","ul","48",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Reflection + streaming don't compose.</strong> Streaming runs the initial"}}]]}],["$","p","49",{"dangerouslySetInnerHTML":{"__html":"  inference. The reflection sub-loop calls the adapter again for the   critique step, which uses the regular non-streaming adapter (the   reflection rubric wants a single concrete output to score, not a token   stream). If you need reflection on the streamed output, persist the   full text from the <code>agent.thinking.end</code> event and run reflection   separately downstream."}}],["$","ul","50",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>A buggy <code>MeshEvent</code> subscriber cannot take down the dispatch.</strong>"}}]]}],["$","p","51",{"dangerouslySetInnerHTML":{"__html":"  Subscriber exceptions are swallowed; sibling subscribers continue to   receive events. Subscribers own their own <code>try/catch</code> for things they   care about."}}],["$","h2","52",{"dangerouslySetInnerHTML":{"__html":"Reference consumer"}}],["$","p","53",{"dangerouslySetInnerHTML":{"__html":"<a href=\"https://github.com/lalla-ai/incomeclaw\">IncomeClaw</a> is the production consumer of these APIs. See <code>incomeclaw/agents/*</code> for typical usage and <code>incomeclaw/apps/web/lib/sse.ts</code> for the wire-up between <code>mesh.onEvent</code> and a frontend EventSource stream."}}]]}]}]]}],["$","footer",null,{"className":"mt-24 border-t border-border bg-surface/40","children":["$","div",null,{"className":"mx-auto max-w-7xl px-6 py-10 text-sm text-muted flex flex-wrap gap-6 justify-between","children":[["$","div",null,{"children":[["$","div",null,{"className":"font-semibold text-text mb-2","children":"SovereignClaw"}],["$","div",null,{"children":"Apache-2.0 licensed."}],["$","div",null,{"className":"mt-1","children":"Built on 0G — Storage Log, Compute Router, EVM chain, ERC-7857."}]]}],["$","div",null,{"className":"flex gap-6","children":[["$","a",null,{"href":"https://github.com/irajgill/SovereignClaw","className":"hover:text-text","children":"GitHub"}],["$","a",null,{"href":"https://www.npmjs.com/org/sovereignclaw","className":"hover:text-text","children":"npm"}],["$","a",null,{"href":"https://chainscan-galileo.0g.ai","className":"hover:text-text","children":"Chainscan"}],["$","a",null,{"href":"https://faucet.0g.ai","className":"hover:text-text","children":"Faucet"}]]}]]}]}]],null],null],null]},[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","primitives","children","streaming","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","primitives","children"],"er