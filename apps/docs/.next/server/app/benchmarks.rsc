,["$","p","3",{"dangerouslySetInnerHTML":{"__html":"Targets referenced below are from the roadmap, §16 \"Performance benchmarks\". A <strong>yes</strong> means we met the target; a <strong>NO</strong> is documented honestly with the measured number + the bounded reason."}}],["$","hr","4",{}],["$","h2","5",{"dangerouslySetInnerHTML":{"__html":"Summary table"}}],["$","table","6",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Benchmark"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Target"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Measured"}}],["$","th","3",{"dangerouslySetInnerHTML":{"__html":"Met?"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Cold start (clone → first run)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"&lt;10 min"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<strong>1 m 24 s</strong> (0 m 15 s offline + 1 m 20 s live)"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"yes"}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Single-agent LoC"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"&lt;30 effective"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<strong>24</strong> effective (<code>minimal-single-agent</code>)"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"yes"}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"3-agent mesh LoC"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"&lt;60 effective"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<strong>27</strong> effective (<code>minimal-3-agent-mesh</code>)"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"yes"}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Inference RTT (cold)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"&lt;8 s"}}],["$","td","2"