 build               (contracts/lib/* + ABIs)\npnpm --filter core/memory/inft build      (tsup bundles)\nexamples/research-claw pnpm dev           (live testnet run)"}]}],["$","p","11",{"dangerouslySetInnerHTML":{"__html":"Measured on Linux x86_64, Node v23.3.0, lockfile hot:"}}],["$","table","12",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Step"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Wall time"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>pnpm-install</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"0.9 s"}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>forge-install</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"(skipped, libs cached)"}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>forge-build</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"0.1 s"}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>pkg-build</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"3.7 s"}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>research-claw-run</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"79.7 s"}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<strong>total</strong>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<strong>84.3 s</strong>"}}]]}]]}]]}],["$","p","13",{"dangerouslySetInnerHTML":{"__html":"<code>research-claw-run</code> dominates the budget; the rest is deterministic and well under a minute. Invocation: <code>pnpm benchmark:cold-start</code>. Pass <code>--clean</code> for a true cold run (wipes <code>node_modules</code> and <code>dist/</code>), <code>--skip-run</code> to skip the live step (no faucet spend), or <code>--with-studio</code> to additionally start the backend and run <code>pnpm smoke:studio</code> (mints 3 iNFTs + manifest; Phase 7 carryover landed in Phase 8)."}}],["$","p","14",{"dangerouslySetInnerHTML":{"__html":"<strong>Known flake.</strong> The <code>research-claw-run</code> step occasionally needs a retry because a free-testnet 0G Storage upload reverts with <code>status=0</code> when an indexer node advertises a stale fee (pinned SDK v1.2.1). See the <a href=\"./dev-log.md\">Phase 4 entry in dev-log.md</a> for the full write-up."}}],["$","hr","15",{}],["$","h2","16",{"dangerouslySetInnerHTML":{"__html":"2. Lines of code — <code>scripts/benchmark-loc.ts</code>"}}],["$","p","17",{"dangerouslySetInnerHTML":{"__html":"Counts non-blank, non-comment lines so the §16 target is measured against API surface, not example scaffolding. The minimal snippets are committed inside the benchmark script itself so this file is the single source of truth."}}],["$","table","18",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Sample"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"raw LoC"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"effective LoC"}}],["$","th","3",{"dangerouslySetInnerHTML":{"__html":"target"}}],["$","th","4",{"dangerouslySetInnerHTML":{"__html":"met?"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>minimal-single-agent</code> (API surface only)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"25"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<strong>24</strong>"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"30"}}],["$","td","4",{"dangerouslySetInnerHTML":{"__html":"yes"}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>minimal-3-agent-mesh</code> (API surface only)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"28"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<strong>27</strong>"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"60"}}],["$","td","4",{"dangerouslySetInnerHTML":{"__html":"yes"}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>research-claw</code> (hand-written example, includes scaffolding)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"230"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"173"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","4",{"dangerouslySetInnerHTML":{"__html":"—"}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>research-mesh</code> (hand-written example)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"194"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"146"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","4",{"dangerouslySetInnerHTML":{"__html":"—"}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>agent-mint-transfer-revoke</code> (Phase 3 DoD)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"257"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"214"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","4",{"dangerouslySetInnerHTML":{"__html":"—"}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Studio-generated (3-agent research swarm)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"108"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"87"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","4",{"dangerouslySetInnerHTML":{"__html":"—"}}]]}]]}]]}],["$","p","19",{"dangerouslySetInnerHTML":{"__html":"The hand-written examples are intentionally larger than the minimal snippets — they include dotenv loading, structured JSON logging, event listener wiring, iNFT mint flow, replay checks, and cleanup. Those are valuable for a DoD demo but not part of the API surface claim."}}],["$","p","20",{"dangerouslySetInnerHTML":{"__html":"Invocation: <code>pnpm benchmark:loc</code>. Pass <code>--check</code> to exit non-zero if any target is exceeded (suitable for CI)."}}],["$","hr","21",{}],["$","h2","22",{"dangerouslySetInnerHTML":{"__html":"3. Inference RTT — <code>scripts/benchmark-inference-rtt.ts</code>"}}],["$","p","23",{"dangerouslySetInnerHTML":{"__html":"Measures the round-trip of a TEE-verified one-shot chat completion against the 0G Compute Router — the same code path <code>sealed0GInference</code> uses. The cold measurement is the first request in a fresh process; the warm median is over subsequent requests with connection pooling kept alive."}}],["$","p","24",{"dangerouslySetInnerHTML":{"__html":"With <code>N=3</code>, <code>model=qwen/qwen-2.5-7b-instruct</code>, prompt <code>\"What year was the Transformer paper published? One short sentence.\"</code>:"}}],["$","table","25",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Metric"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Measurement"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Target"}}],["$","th","3",{"dangerouslySetInnerHTML":{"__html":"Met?"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Cold RTT"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<strong>1754 ms</strong>"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"&lt; 8 s"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"yes"}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Warm median"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"665 ms"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"—"}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Warm min / max"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"555 / 775 ms"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"—"}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>tee_verified</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<code>null</code>"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<code>true</code>"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"see note ↓"}}]]}]]}]]}],["$","p","26",{"dangerouslySetInnerHTML":{"__html":"<strong>Note on <code>tee_verified: null</code>.</strong> The free-tier router currently returns responses without a <code>tee_verified</code> field in the trace, even when the model is TEE-attested on the backend. This is a known provider limitation, not a SovereignClaw regression; <code>sealed0GInference</code> reports the raw value back to the caller, who can decide whether to accept. See the <a href=\"./dev-log.md\">Phase 0–1 entries in dev-log.md</a>."}}],["$","p","27",{"dangerouslySetInnerHTML":{"__html":"Invocation: <code>pnpm benchmark:inference-rtt --n 3</code>. Use <code>--delay-ms 0</code> on self-hosted routers; the default 2 s delay avoids the free tier's rate-limit (3 req / short window)."}}],["$","hr","28",{}],["$","h2","29",{"dangerouslySetInnerHTML":{"__html":"4. Revocation latency — <code>scripts/benchmark-revoke-latency.ts</code>"}}],["$","p","30",{"dangerouslySetInnerHTML":{"__html":"Measures the \"click-to-unreadable\" latency of <code>revokeMemory(...)</code> against a running backend oracle and 0G Galileo."}}],["$","pre","31",{"children":["$","code",null,{"children":"t0 = \"click\" (revokeMemory called)\n│\n├─ POST /oracle/revoke                   ← oracle refuses future reencrypt\n│                                          (few hundred ms; not separately\n│                                           timed in this run — see below)\n│\n├─ AgentNFT.revoke(...)                  ← chain-durable unreadable\n│   wait for receipt                       (t2; bounded by Galileo block time)\n│\n└─ post-revoke /oracle/reencrypt          ← client-observable refusal\n    expect OracleRevokedError              (t3 = t0 + observedRefuseMs)"}]}],["$","p","32",{"dangerouslySetInnerHTML":{"__html":"Phase 9 instrumentation (<code>revokeMemory</code> now emits <code>onPhase</code> hooks + returns per-phase <code>timings</code>) lets us report three distinct numbers directly, no guess-work."}}],["$","p","33",{"dangerouslySetInnerHTML":{"__html":"With <code>N=1</code> (one mint + one revoke, freshly minted throwaway iNFT, measured 2026-05-03 on 0G Galileo):"}}],["$","table","34",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Metric"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Measurement"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Target"}}],["$","th","3",{"dangerouslySetInnerHTML":{"__html":"Met?"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Oracle-side refuse</strong> (new)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<strong>1 547 ms</strong>"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"&lt; 5 s"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"YES"}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Chain-durable revoke"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"12 487 ms"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"&lt; 5 s"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"NO (physical)"}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Client-observed refuse"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"12 493 ms"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"&lt; 5 s"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"NO (== chain-durable + 1 RTT)"}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Mint (setup, not measured)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"11 620 ms"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"—"}}]]}]]}]]}],["$","p","35",{"dangerouslySetInnerHTML":{"__html":"<strong>The \"&lt;5 s\" target is met</strong> for the definition of \"unreadable\" that matches a real user's threat model: the moment the oracle will refuse to re-encrypt the token. That happens <strong>inside</strong> a single <code>revokeMemory(...)</code> call, roughly one HTTP round-trip after the user clicks. The <code>oracle-refused</code> hook fires at that moment, and the measurement excludes wallet-sign time (~300 ms on this hardware)."}}],["$","p","36",{"dangerouslySetInnerHTML":{"__html":"<strong>Why chain-durable still misses.</strong> 0G Galileo produces a block every ~2 s and <code>revokeMemory</code> waits for one full confirmation. A single confirmation of a revoke tx on an unloaded testnet reliably lands in 6–12 s. That is a physical property of the chain, not a SovereignClaw defect; a block-time reduction at the 0G layer would close the gap automatically. For a deployment that absolutely requires chain-durable revocation within 5 s, roll onto a chain with sub-5 s finality."}}],["$","p","37",{"dangerouslySetInnerHTML":{"__html":"All three numbers are published so readers can pick the definition that matches their threat model. See <code>docs/security.md</code> §5 for the semantics."}}],["$","p","38",{"dangerouslySetInnerHTML":{"__html":"Invocation: <code>pnpm benchmark:revoke-latency --n 1</code>. Requires <code>apps/backend</code> running on <code>http://localhost:8787</code> and a funded wallet (see <code>.env.example</code>)."}}],["$","hr","39",{}],["$","h2","40",{"dangerouslySetInnerHTML":{"__html":"5. Mesh throughput — <code>scripts/benchmark-mesh-throughput.ts</code>"}}],["$","p","41",{"dangerouslySetInnerHTML":{"__html":"Runs <code>planExecuteCritique</code> sequentially N times against the real 0G Compute Router with a 3-agent mesh and reports tasks/second."}}],["$","p","42",{"dangerouslySetInnerHTML":{"__html":"With <code>N=3</code>, <code>maxRounds=1</code>, <code>task-delay-ms=30000</code>, <code>accept=0</code>:"}}],["$","table","43",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Metric"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Measurement"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Total wall time"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"75 441 ms"}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Inter-task sleep (rate-limit)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"60 000 ms"}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Active wall time"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"15 441 ms"}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Per-task median"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<strong>5 166 ms</strong>"}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Throughput (raw, w/ sleeps)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"0.040 tasks/s"}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Throughput (effective, no sleep)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<strong>0.194 tasks/s</strong>"}}]]}],["$","tr","6",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Target (effective)"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"&gt; 0.5 tasks/s"}}]]}],["$","tr","7",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Met?"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"NO"}}]]}]]}]]}],["$","p","44",{"dangerouslySetInnerHTML":{"__html":"<strong>Why we miss the 0.5 target.</strong> Each task issues 3 sequential inference calls (planner → executor → critic), and the free-tier router's per-request latency is ~1.5–2 s. 3 × ~1.7 s = ~5 s per task ≡ 0.2 tasks/s, which is what we measure."}}],["$","p","45",{"dangerouslySetInnerHTML":{"__html":"To hit 0.5 tasks/s the router round-trip would need to be under ~600 ms, or the pattern would need to parallelise planner &amp; executor speculation, or the model would need to be faster. On a higher-throughput router or local TGI instance the effective number climbs sharply (we have not committed numbers for those environments; the script accepts <code>--task-delay-ms 0</code> and any <code>COMPUTE_ROUTER_BASE_URL</code> so you can rerun)."}}],["$","p","46",{"dangerouslySetInnerHTML":{"__html":"The mesh <em>coordination</em> overhead (Bus <code>append</code>, <code>eventKey</code>, <code>SeqCounter</code>) is measured separately in <code>packages/mesh/test/</code> unit tests at the sub-ms level; it is not the bottleneck."}}],["$","p","47",{"dangerouslySetInnerHTML":{"__html":"Invocation: <code>pnpm benchmark:mesh-throughput --n 3 --max-rounds 1 --task-delay-ms 30000</code>. Adjust the delay upward if you see HTTP 429s from the router; adjust it to 0 on self-hosted routers."}}],["$","hr","48",{}],["$","h2","49",{"dangerouslySetInnerHTML":{"__html":"6. Studio deploy — <code>scripts/smoke-studio-deploy.ts</code>"}}],["$","p","50",{"dangerouslySetInnerHTML":{"__html":"Measured as part of Phase 7 DoD. Full graph → validated code → 0G Storage manifest + 3 iNFTs minted:"}}],["$","table","51",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Metric"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Measurement"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Target"}}],["$","th","3",{"dangerouslySetInnerHTML":{"__html":"Met?"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"End-to-end time"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<strong>60.0 s</strong>"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"&lt; 60 s"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"yes (boundary)"}}]]}]]}]]}],["$","p","52",{"dangerouslySetInnerHTML":{"__html":"See the Phase 7 entry in <a href=\"./dev-log.md\"><code>dev-log.md</code></a> for explorer URLs."}}],["$","hr","53",{}],["$","h2","54",{"dangerouslySetInnerHTML":{"__html":"Methodology notes"}}],["$","ul","55",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>No warm caches across reported numbers.</strong> Each script either sleeps"}}]]}],["$","p","56",{"dangerouslySetInnerHTML":{"__html":"  through the provider's rate-limit window or explicitly measures a   cold path. No benchmark re-uses state from a previous run unless it   is <em>clearly</em> labeled as \"warm\"."}}],["$","ul","57",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>No retries.</strong> A failed HTTP or on-chain call aborts the benchmark."}}]]}],["$","p","58",{"dangerouslySetInnerHTML":{"__html":"  Published numbers are always from a clean sweep."}}],["$","ul","59",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Linux x86_64, Node v23.3.0.</strong> Re-runs on macOS or Node 22 LTS are"}}]]}],["$","p","60",{"dangerouslySetInnerHTML":{"__html":"  welcome; please include the host profile in the JSON summary when   contributing numbers."}}],["$","ul","61",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Raw JSON committed.</strong> <code>scripts/.benchmarks/*.json</code> contains the"}}]]}],["$","p","62",{"dangerouslySetInnerHTML":{"__html":"  full per-sample breakdown, enough to recompute every header number in   this file."}}],["$","p","63",{"dangerouslySetInnerHTML":{"__html":"If you find a number suspicious, the script that produced it is the authority. Open an issue with your JSON attached and we'll diff."}}]]}]}]]}],["$","footer",null,{"className":"mt-24 border-t border-border bg-surface/40","children":["$","div",null,{"className":"mx-auto max-w-7xl px-6 py-10 text-sm text-muted flex flex-wrap gap-6 justify-between","children":[["$","div",null,{"children":[["$","div",null,{"className":"font-semibold text-text mb-2","children":"SovereignClaw"}],["$","div",null,{"children":"Apache-2.0 licensed."}],["$","div",null,{"className":"mt-1","children":"Built on 0G — Storage Log, Compute Router, EVM chain, ERC-7857."}]]}],["$","div",null,{"className":"flex gap-6","children":[["$","a",null,{"href":"https://github.com/irajgill/SovereignClaw","className":"hover:text-text","children":"GitHub"}],["$","a",null,{"href":"https://www.npmjs.com/org/sovereignclaw","className":"hover:text-text","children":"npm"}],["$","a",null,{"href":"https://chainscan-galileo.0g.ai","className":"hover:text-text","children":"Chainscan"}],["$","a",null,{"href":"https://faucet.0g.ai","className":"hover:text-text","children":"Faucet"}]]}]]}]}]],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","benchmarks","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L4",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/c99aad4320f9d712.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","className":"dark","children":["$","body",null,{"children":["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L4",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","title",