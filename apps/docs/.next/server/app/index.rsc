,{"className":"mt-8 flex flex-wrap gap-3","children":[["$","$L2",null,{"href":"/quickstart","className":"inline-flex items-center rounded-lg bg-accent text-white px-5 py-3 text-sm font-medium hover:opacity-90 transition-opacity","children":"Quickstart →"}],["$","a",null,{"href":"https://github.com/irajgill/SovereignClaw","target":"_blank","rel":"noreferrer","className":"inline-flex items-center rounded-lg bg-surface-2 border border-border-2 px-5 py-3 text-sm font-medium hover:border-accent-2 transition-colors","children":"GitHub"}],["$","a",null,{"href":"https://oracle-production-5db4.up.railway.app/healthz","target":"_blank","rel":"noreferrer","className":"inline-flex items-center rounded-lg bg-surface-2 border border-border-2 px-5 py-3 text-sm font-medium hover:border-accent-2 transition-colors","children":"Live oracle"}]]}]]}],["$","section",null,{"className":"mx-auto max-w-6xl px-6 pb-20","children":["$","div",null,{"className":"rounded-xl border border-border bg-surface/40 overflow-hidden","children":[["$","div",null,{"className":"flex flex-wrap border-b border-border bg-surface-2/40","children":[["$","a","agent",{"href":"#snippet-agent","className":"px-5 py-3 text-sm border-r border-border text-text bg-surface","children":"Define an agent"}],["$","a","inft",{"href":"#snippet-inft","className":"px-5 py-3 text-sm border-r border-border text-muted hover:text-text","children":"Mint as iNFT"}],["$","a","mesh",{"href":"#snippet-mesh","className":"px-5 py-3 text-sm border-r border-border text-muted hover:text-text","children":"Wire a swarm"}],["$","a","revoke",{"href":"#snippet-revoke","className":"px-5 py-3 text-sm border-r border-border text-muted hover:text-text","children":"Revoke memory"}]]}],["$","div",null,{"className":"grid md:grid-cols-1 gap-0","children":[["$","div","agent",{"id":"snippet-agent","className":"p-6 border-b border-border last:border-0","children":[["$","div",null,{"className":"text-xs uppercase tracking-widest text-muted font-semibold mb-3","children":"Define an agent"}],["$","pre",null,{"children":["$","code",null,{"children":"// Define an agent in ~20 lines\nimport { Agent, sealed0GInference } from '@sovereignclaw/core';\nimport { OG_Log, encrypted, deriveKekFromSigner } from '@sovereignclaw/memory';\nimport { reflectOnOutput } from '@sovereignclaw/reflection';\n\nconst kek = await deriveKekFromSigner(signer, 'research-claw-v1');\nconst research = new Agent({\n  role: 'researcher',\n  inference: sealed0GInference({\n    model: 'qwen/qwen-2.5-7b-instruct',\n    apiKey: process.env.COMPUTE_ROUTER_API_KEY!,\n    verifiable: true,\n  }),\n  memory: encrypted(OG_Log({ namespace: 'research', ... }), { kek }),\n  reflect: reflectOnOutput({ rounds: 1, rubric: 'accuracy' }),\n});\n\nawait research.run('Summarize recent papers on retrieval-augmented agents.');"}]}]]}],["$","div","inft",{"id":"snippet-inft","className":"p-6 border-b border-border last:border-0","children":[["$","div",null,{"className":"text-xs uppercase tracking-widest text-muted font-semibold mb-3","children":"Mint as iNFT"}],["$","pre",null,{"children":["$","code",null,{"children":"// Mint an agent as an iNFT\nimport { mintAgentNFT } from '@sovereignclaw/inft';\n\nconst { tokenId, txHash, explorerUrl } = await mintAgentNFT({\n  agent: research,\n  owner: userWallet,\n  royaltyBps: 500,           // 5% on every UsageRecorded event\n  deployment,                // loaded once via loadDeployment()\n});\nconsole.log(`token #${tokenId} → ${explorerUrl}`);"}]}]]}],["$","div","mesh",{"id":"snippet-mesh","className":"p-6 border-b border-border last:border-0","children":[["$","div",null,{"className":"text-xs uppercase tracking-widest text-muted font-semibold mb-3","children":"Wire a swarm"}],["$","pre",null,{"children":["$","code",null,{"children":"// Wire a swarm with the unified MeshEvent surface\nimport { Mesh, sequentialPattern } from '@sovereignclaw/mesh';\n\nconst mesh = new Mesh({ meshId: 'income-team', provider: busProvider });\nmesh.register(brain).register(strategist).register(opener).register(closer);\n\n// One subscription, every signal — thinking tokens, tool chips, handoffs.\nmesh.onEvent((e) => ui.handle(e));\n\nawait mesh.dispatch(\n  'Find me a $10K AI consulting deal.',\n  sequentialPattern({ agentNames: ['brain', 'strategist', 'opener', 'closer'] }),\n);"}]}]]}],["$","div","revoke",{"id":"snippet-revoke","className":"p-6 border-b border-border last:border-0","children":[["$","div",null,{"className":"text-xs uppercase tracking-widest text-muted font-semibold mb-3","children":"Revoke memory"}],["$","pre",null,{"children":["$","code",null,{"children":"// Revoke memory in one call\nimport { revokeMemory } from '@sovereignclaw/inft';\n\nawait revokeMemory({ tokenId, owner: userWallet, oracle });\n// On-chain wrappedDEK is zeroed irrevocably,\n// MemoryRevocation registry is updated,\n// the oracle refuses any future re-encryption for this token.\n// Verifiable on chainscan-galileo.0g.ai. Phase 9 measured 1.5s end-to-end."}]}]]}]]}]]}]}],["$","section",null,{"className":"mx-auto max-w-6xl px-6 pb-20","children":[["$","h2",null,{"className":"text-2xl font-semibold mb-8","children":"Why SovereignClaw"}],["$","div",null,{"className":"grid md:grid-cols-2 gap-5","children":[["$","div","Sovereign by default",{"className":"rounded-lg border border-border bg-surface-2/40 p-5","children":[["$","div",null,{"className":"text-text font-semibold mb-2","children":"Sovereign by default"}],["$","div",null,{"className":"text-muted text-sm leading-relaxed","children":"Encrypted memory wrapped under wallet-derived KEKs (AES-256-GCM + HKDF-SHA-256). Revocation is irreversible and on-chain — chainscan-verifiable."}]]}],["$","div","TEE-verifiable inference",{"className":"rounded-lg border border-border bg-surface-2/40 p-5","children":[["$","div",null,{"className":"text-text font-semibold mb-2","children":"TEE-verifiable inference"}],["$","div",null,{"className":"text-muted text-sm leading-relaxed","children":"Streaming SSE over 0G Compute Router with verify_tee=true. Every InferenceResult carries the TEE attestation envelope and per-call billing."}]]}],["$","div","iNFT lifecycle in one call",{"className":"rounded-lg border border-border bg-surface-2/40 p-5","children":[["$","div",null,{"className":"text-text font-semibold mb-2","children":"iNFT lifecycle in one call"}],["$","div",null,{"className":"text-muted text-sm leading-relaxed","children":"mintAgentNFT / transferAgentNFT / revokeMemory / recordUsage. ERC-7857 oracle wraps the DEK on transfer; the chain enforces revocation."}]]}],["$","div","Swarms with one event subscription",{"className":"rounded-lg border border-border bg-surface-2/40 p-5","children":[["$","div",null,{"className":"text-text font-semibold mb-2","children":"Swarms with one event subscription"}],["$","div",null,{"className":"text-muted text-sm leading-relaxed","children":"mesh.onEvent(e => …) emits agent.thinking.token, agent.action.start, agent.handoff, task.complete. The streaming UI you want, free."}]]}],["$","div","Visual builder ships in the box",{"className":"rounded-lg border border-border bg-surface-2/40 p-5","children":[["$","div",null,{"className":"text-text font-semibold mb-2","children":"Visual builder ships in the box"}],["$","div",null,{"className":"text-muted text-sm leading-relaxed","children":"ClawStudio drag-and-drop graph → SovereignClaw code → one-click iNFT deploy. The same code path the example uses."}]]}]]}]]}],["$","section",null,{"className":"mx-auto max-w-6xl px-6 pb-20","children":[["$","h2",null,{"className":"text-2xl font-semibold mb-4","children":"Live on 0G Galileo Testnet"}],["$","p",null,{"className":"text-muted mb-6","children":"Real contracts, real iNFT mints, real TEE-attested inference. Click through and verify on chainscan."}],["$","div",null,{"className":"rounded-lg border border-border bg-surface-2/40 overflow-x-auto","children":["$","table",null,{"className":"w-full text-sm","children":[["$","thead",null,{"children":["$",