,null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Tool"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Version"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Install"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Node.js"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"22 LTS"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"https://nodejs.org / <code>nvm install 22</code>"}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"pnpm"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"9+"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<code>corepack enable &amp;&amp; corepack prepare pnpm@9 --activate</code>"}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Foundry"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"latest"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"`curl -L https://foundry.paradigm.xyz \\"}}],["$","td","3",{"dangerouslySetInnerHTML":{"__html":"bash &amp;&amp; foundryup`"}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"git"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"any recent"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"(system package manager)"}}]]}]]}]]}],["$","p","5",{"dangerouslySetInnerHTML":{"__html":"You also need <strong>two testnet balances</strong> on 0G Galileo (chainId <code>16602</code>):"}}],["$","ol","6",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Wallet</strong> — funds gas for storage writes and the mint. Free from"}}]]}],["$","p","7",{"dangerouslySetInnerHTML":{"__html":"   https://faucet.0g.ai (0.1 0G/day is more than enough)."}}],["$","ol","8",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Router</strong> — funds inference calls. Deposit at"}}]]}],["$","p","9",{"dangerouslySetInnerHTML":{"__html":"   https://pc.testnet.0g.ai and copy the issued API key."}}],["$","p","10",{"dangerouslySetInnerHTML":{"__html":"Both are decoupled. A tiny deposit on each (~0.01 0G) carries you through tens of ResearchClaw runs."}}],["$","h2","11",{"dangerouslySetInnerHTML":{"__html":"1. Clone and configure env"}}],["$","pre","12",{"children":["$","code",null,{"children":"git clone https://github.com/irajgill/SovereignClaw.git\ncd SovereignClaw\ncp .env.example .env"}]}],["$","p","13",{"dangerouslySetInnerHTML":{"__html":"Open <code>.env</code> and fill, at minimum:"}}],["$","pre","14",{"children":["$","code",null,{"children":"PRIVATE_KEY=0x...                               # funded 0G Galileo wallet\nCOMPUTE_ROUTER_API_KEY=sk-...                   # from https://pc.testnet.0g.ai"}]}],["$","p","15",{"dangerouslySetInnerHTML":{"__html":"Everything else (<code>RPC_URL</code>, <code>INDEXER_URL</code>, <code>EXPLORER_URL</code>, <code>COMPUTE_MODEL</code>, etc.) is pre-set for the public testnet."}}],["$","p","16",{"dangerouslySetInnerHTML":{"__html":"If you also plan to run the Phase 3 mint → transfer → revoke example, you will additionally need <code>BOB_PRIVATE_KEY</code> and a dev oracle (see <code>examples/agent-mint-transfer-revoke/README.md</code>). ResearchClaw does not need those."}}],["$","h2","17",{"dangerouslySetInnerHTML":{"__html":"2. Install JavaScript + Solidity deps"}}],["$","pre","18",{"children":["$","code",null,{"children":"pnpm install\n(\n  cd contracts\n  forge install foundry-rs/forge-std --no-git\n  forge install OpenZeppelin/openzeppelin-contracts --no-git\n  forge build\n)"}]}],["$","p","19",{"dangerouslySetInnerHTML":{"__html":"The <code>forge build</code> step produces <code>contracts/out/AgentNFT.sol/AgentNFT.json</code> which <code>@sovereignclaw/inft</code> imports for its ABI bindings."}}],["$","h2","20",{"dangerouslySetInnerHTML":{"__html":"3. Build the workspace packages"}}],["$","pre","21",{"children":["$","code",null,{"children":"pnpm --filter @sovereignclaw/core \\\n     --filter @sovereignclaw/memory \\\n     --filter @sovereignclaw/reflection \\\n     --filter @sovereignclaw/inft build"}]}],["$","h2","22",{"dangerouslySetInnerHTML":{"__html":"4. Sanity-check your setup"}}],["$","pre","23",{"children":["$","code",null,{"children":"pnpm check:deployment    # 10/10 on-chain assertions\npnpm smoke:storage       # writes 1 KB to 0G, reads it back\npnpm smoke:compute       # one inference call, asserts tee_verified: true"}]}],["$","p","24",{"dangerouslySetInnerHTML":{"__html":"<code>pnpm check:deployment</code> asserts the live <code>AgentNFT</code> and <code>MemoryRevocation</code> contracts on Galileo still match the committed record in <code>deployments/0g-testnet.json</code>. It takes ~4 seconds."}}],["$","p","25",{"dangerouslySetInnerHTML":{"__html":"<code>pnpm smoke:storage</code> and <code>pnpm smoke:compute</code> are the Phase 0 rails — if either fails, ResearchClaw will too."}}],["$","h2","26",{"dangerouslySetInnerHTML":{"__html":"5. Run ResearchClaw"}}],["$","pre","27",{"children":["$","code",null,{"children":"cd examples/research-claw\npnpm dev"}]}],["$","p","28",{"dangerouslySetInnerHTML":{"__html":"Expected: ~80 seconds end-to-end on a fresh machine (two storage uploads, one inference call, one manifest write, one mint tx). Output looks like:"}}],["$","pre","29",{"children":["$","code",null,{"children":"{ \"step\": \"start\", \"owner\": \"0x...\", \"chainId\": 16602, \"AgentNFT\": \"0xc3f9975...\", \"model\": \"qwen/qwen-2.5-7b-instruct\" }\n{ \"step\": \"run.start\", \"runId\": \"...\" }\n{ \"step\": \"run.complete\", \"runId\": \"...\", \"latencyMs\": 7738, \"teeVerified\": true, \"providerAddress\": \"0xa48f...\", \"totalCostWei\": \"54850000000000\" }\n\n=== ResearchClaw output ===\n<model answer>\n===========================\n\n{ \"step\": \"manifest\", \"pointer\": \"0x6bbbe5...bb08de\" }\n{ \"step\": \"mint\", \"tokenId\": \"11\", \"txHash\": \"0x76e7c8...56717\", \"explorerUrl\": \"https://chainscan-galileo.0g.ai/tx/0x...\" }\n{ \"step\": \"done\", \"summary\": \"ResearchClaw ran, persisted encrypted memory on 0G, and minted the agent as an iNFT.\" }"}]}],["$","p","30",{"dangerouslySetInnerHTML":{"__html":"Click the <code>explorerUrl</code> to see your newly minted iNFT on chainscan-galileo."}}],["$","h2","31",{"dangerouslySetInnerHTML":{"__html":"What just happened"}}],["$","table","32",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"You did"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Under the hood"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>pnpm dev</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Loaded <code>.env</code>, bound a signer to 0G Galileo."}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Derived a KEK from your wallet signature (EIP-191 → HKDF-SHA-256)."}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Built <code>encrypted(OG_Log(...))</code> providers — AES-256-GCM on every write."}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Called 0G Compute Router with <code>verify_tee: true</code>."}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Saw <code>teeVerified: true</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<code>x_0g_trace.tee_verified</code> in the Router response, signed by the provider's TEE attestation."}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"—"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"Wrote context + history + manifest to 0G Storage Log."}}]]}],["$","tr","6",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"Saw <code>tokenId: 11</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<code>AgentNFT.mint(...)</code> tx on 0G Chain at <code>0xc3f9975...</code>."}}]]}]]}]]}],["$","p","33",{"dangerouslySetInnerHTML":{"__html":"Four primitives, one command, all real on-chain artifacts."}}],["$","h2","34",{"dangerouslySetInnerHTML":{"__html":"Cold-start benchmark"}}],["$","p","35",{"dangerouslySetInnerHTML":{"__html":"Want to verify the &lt;10 min claim on your machine?"}}],["$","pre","36",{"children":["$","code",null,{"children":"pnpm benchmark:cold-start            # in-place (uses current node_modules)\npnpm benchmark:cold-start --clean    # true cold: wipes node_modules first\npnpm benchmark:cold-start --skip-run # no live testnet call (CI smoke)"}]}],["$","p","37",{"dangerouslySetInnerHTML":{"__html":"The benchmark times five steps and writes a JSON report to <code>scripts/.benchmarks/cold-start.json</code>. Measured reference numbers from the Phase 4 DoD run on a Linux x64 workstation (Node 23.3, in-place flags):"}}],["$","table","38",{"children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th","0",{"dangerouslySetInnerHTML":{"__html":"Step"}}],["$","th","1",{"dangerouslySetInnerHTML":{"__html":"Time"}}],["$","th","2",{"dangerouslySetInnerHTML":{"__html":"Notes"}}]]}]}],["$","tbody",null,{"children":[["$","tr","0",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>pnpm install</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"~1s"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"warm lockfile, no network fetches"}}]]}],["$","tr","1",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>forge install</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"skipped"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"<code>contracts/lib/*</code> already present"}}]]}],["$","tr","2",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>forge build</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"~0.1s"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"incremental"}}]]}],["$","tr","3",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>pkg-build</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"~4s"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"core + memory + inft in parallel"}}]]}],["$","tr","4",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<code>research-claw-run</code>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"~80s"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"3 storage writes + inference + mint"}}]]}],["$","tr","5",{"children":[["$","td","0",{"dangerouslySetInnerHTML":{"__html":"<strong>Total</strong>"}}],["$","td","1",{"dangerouslySetInnerHTML":{"__html":"<strong>~85s</strong>"}}],["$","td","2",{"dangerouslySetInnerHTML":{"__html":"— see <code>scripts/.benchmarks/cold-start.json</code>"}}]]}]]}]]}],["$","p","39",{"dangerouslySetInnerHTML":{"__html":"A true first-clone cold start (wiping <code>node_modules</code> and <code>contracts/lib</code>) adds ~10s for <code>pnpm install</code> downloads and ~15s for <code>forge install</code>, putting the clone-to-mint path at roughly <strong>2 minutes of wall time</strong>. The &lt;10 min DX target in <code>claude.md</code> §16 has substantial headroom."}}],["$","h3","40",{"dangerouslySetInnerHTML":{"__html":"Honest flake note"}}],["$","p","41",{"dangerouslySetInnerHTML":{"__html":"The pinned <code>@0gfoundation/0g-ts-sdk@1.2.1</code> rotates across 0G indexer nodes that advertise inconsistent storage fees. In the Phase 4 verification session, roughly <strong>1 in 3 runs</strong> reverted on the first storage upload with <code>status=0</code> on the Flow contract. A simple retry of <code>pnpm dev</code> hit a different node and succeeded. If you're scripting around this, handle the <code>StorageSdkError</code> thrown by <code>@sovereignclaw/memory</code> and retry up to 3 times. See <code>docs/dev-log.md</code> Phase 3 for the tracking note."}}],["$","h2","42",{"dangerouslySetInnerHTML":{"__html":"Troubleshooting"}}],["$","h3","43",{"dangerouslySetInnerHTML":{"__html":"<code>missing required env var PRIVATE_KEY</code>"}}],["$","p","44",{"dangerouslySetInnerHTML":{"__html":"Copy <code>.env.example</code> → <code>.env</code> and fill <code>PRIVATE_KEY</code>. The loader walks from example dir up to the repo root, so either location works."}}],["$","h3","45",{"dangerouslySetInnerHTML":{"__html":"<code>RouterBalanceError</code> / HTTP 402 on the inference call"}}],["$","p","46",{"dangerouslySetInnerHTML":{"__html":"The Router account tied to <code>COMPUTE_ROUTER_API_KEY</code> has zero balance. Deposit testnet 0G at https://pc.testnet.0g.ai and retry."}}],["$","h3","47",{"dangerouslySetInnerHTML":{"__html":"<code>StorageSdkError: OG_Log: upload failed ...  status=0</code>"}}],["$","p","48",{"dangerouslySetInnerHTML":{"__html":"Transient indexer-node flake on the pinned <code>@0gfoundation/0g-ts-sdk@1.2.1</code>. Retry once or twice — each retry rotates to a different storage node. See <code>docs/dev-log.md</code> Phase 3 for the tracking note."}}],["$","h3","49",{"dangerouslySetInnerHTML":{"__html":"<code>Cannot find module '@sovereignclaw/core'</code> (or memory/inft)"}}],["$","p","50",{"dangerouslySetInnerHTML":{"__html":"You skipped step 3. Run the workspace builds."}}],["$","h3","51",{"dangerouslySetInnerHTML":{"__html":"<code>Cannot find module '../../../contracts/out/AgentNFT.sol/AgentNFT.json'</code>"}}],["$","p","52",{"dangerouslySetInnerHTML":{"__html":"You skipped <code>forge build</code>. Run step 2's contracts block."}}],["$","h3","53",{"dangerouslySetInnerHTML":{"__html":"<code>MintError: contract call reverted</code>"}}],["$","p","54",{"dangerouslySetInnerHTML":{"__html":"Your wallet is probably out of gas. Check the balance:"}}],["$","pre","55",{"children":["$","code",null,{"children":"node -e \"const e=require('ethers'); (async()=>{ const p=new e.JsonRpcProvider('https://evmrpc-testnet.0g.ai'); console.log(e.formatEther(await p.getBalance('0xYOUR_ADDRESS')), '0G'); })()\""}]}],["$","p","56",{"dangerouslySetInnerHTML":{"__html":"Top up at https://faucet.0g.ai."}}],["$","h3","57",{"dangerouslySetInnerHTML":{"__html":"<code>check:deployment</code> fails with <code>oracle mismatch</code>"}}],["$","p","58",{"dangerouslySetInnerHTML":{"__html":"Only matters for the Phase 3 example — ResearchClaw does not touch the oracle."}}],["$","h2","59",{"dangerouslySetInnerHTML":{"__html":"Next"}}],["$","ul","60",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<code>examples/agent-mint-transfer-revoke/</code> — Phase 3 lifecycle (transfer with"}}]]}],["$","p","61",{"dangerouslySetInnerHTML":{"__html":"  re-encryption + revoke)."}}],["$","ul","62",{"children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<code>docs/security.md</code> — the trust model and the dev-oracle caveat."}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"<code>docs/dev-log.md</code> — phase-by-phase build log."}}]]}]]}]}]]}],["$","footer",null,{"className":"mt-24 border-t border-border bg-surface/40","children":["$","div",null,{"className":"mx-auto max-w-7xl px-6 py-10 text-sm text-muted flex flex-wrap gap-6 justify-between","children":[["$","div",null,{"children":[["$","div",null,{"className":"font-semibold text-text mb-2","children":"SovereignClaw"}],["$","div",null,{"children":"Apache-2.0 licensed."}],["$","div",null,{"className":"mt-1","children":"Built on 0G — Storage Log, Compute Router, EVM chain, ERC-7857."}]]}],["$","div",null,{"className":"flex gap-6","children":[["$","a",null,{"href":"https://github.com/irajgill/SovereignClaw","className":"hover:text-text","children":"GitHub"}],["$","a",null,{"href":"https://www.npmjs.com/org/sovereignclaw","className":"hover:text-text","children":"npm"}],["$","a",null,{"href":"https://chainscan-galil