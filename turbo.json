{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "package.json", "tsconfig.json", "tsup.config.ts"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "test/**", "package.json"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false,
      "env": ["INTEGRATION", "RPC_URL", "PRIVATE_KEY", "INDEXER_URL", "COMPUTE_ROUTER_API_KEY"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", "test/**", "eslint.config.js", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "test/**", "tsconfig.json"]
    },
    "clean": {
      "cache": false
    }
  }
}
