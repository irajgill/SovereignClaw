# 0G Galileo Testnet - see docs.0g.ai for current values
RPC_URL=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
EXPLORER_URL=https://chainscan-galileo.0g.ai
STORAGE_EXPLORER_URL=https://storagescan-galileo.0g.ai

# Funded testnet wallet - NEVER commit a real key
PRIVATE_KEY=0x_replace_with_64_hex_chars

# Initial oracle address for AgentNFT (Phase 2 deploy). Rotatable later
# via setOracle. Phase 2 used the deployer address as a placeholder;
# Phase 3 swaps in the real dev-oracle keypair from apps/backend.
ORACLE_ADDRESS=0x_replace_with_oracle_address

# Dev-oracle private key used by apps/backend. Generate with:
#   pnpm gen:oracle-key
# NEVER commit a real value. Treat like a wallet key.
ORACLE_PRIVATE_KEY=0x_replace_with_64_hex_chars

# Optional: bearer token gate on apps/backend. If set, all oracle requests
# must carry "Authorization: Bearer <token>". Both the backend and any
# OracleClient instances need to agree on this.
ORACLE_AUTH_TOKEN=

# Second funded testnet wallet for the Phase 3 lifecycle example.
# (Alice = PRIVATE_KEY above, Bob = BOB_PRIVATE_KEY).
BOB_PRIVATE_KEY=0x_replace_with_64_hex_chars

# Where the dev oracle is reachable (default: the docker-compose port).
ORACLE_URL=http://localhost:8787

# 0G Compute Router (testnet)
COMPUTE_ROUTER_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
COMPUTE_ROUTER_API_KEY=replace_me
COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# Studio deploy auth (Phase 9). Comma-separated list of 0x addresses
# that are allowed to submit signed /studio/deploy requests. When empty
# OR unset, the backend runs in OPEN MODE and accepts unsigned deploys —
# suitable for local dev ONLY. Before exposing the backend to the
# network, set this to a non-empty list. Each signer must present an
# EIP-712 sig over {graphSha, nonce, timestamp}.
STUDIO_SIGNER_ALLOWLIST=

# Max drift (seconds) between the client-signed timestamp and server
# now. Defaults to 300 (±5 min). Tighten to 60 with NTP in production.
STUDIO_SIGNATURE_MAX_DRIFT_SEC=300

#npm auth token for private packages (if needed) - NEVER commit a real token
NPM_TOKEN=npm_replace_with_real_token

#railway deploy token - NEVER commit a real token
RAILWAY_TOKEN=replace_me

#if your backend needs to call other APIs, you can put those keys here too. Just remember to NEVER commit real secrets.
ORACLE_AUTH_TOKEN_PROD=replace_me


# Logging
LOG_LEVEL=info
