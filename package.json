{
  "name": "sovereignclaw",
  "version": "0.0.0",
  "private": true,
  "description": "Sovereign-memory, multi-agent, iNFT-native agent framework for 0G.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "INTEGRATION=1 turbo run test:integration",
    "lint": "prettier --check . && turbo run lint",
    "lint:fix": "prettier --write . && turbo run lint -- --fix",
    "typecheck": "turbo run typecheck && tsc -p scripts/tsconfig.json --noEmit",
    "clean": "turbo run clean && rm -rf node_modules contracts/out contracts/cache",
    "smoke": "tsx scripts/smoke-test-0g.ts",
    "smoke:storage": "tsx scripts/smoke-test-0g.ts storage",
    "smoke:compute": "tsx scripts/smoke-test-0g.ts compute",
    "smoke:chain": "tsx scripts/smoke-test-0g.ts chain",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vvv",
    "contracts:snapshot": "cd contracts && forge snapshot --no-match-contract AgentNFTInvariantTest --snap .gas-snapshot",
    "contracts:snapshot:check": "cd contracts && forge snapshot --no-match-contract AgentNFTInvariantTest --check .gas-snapshot",
    "deploy:contracts": "tsx scripts/deploy-contracts.ts",
    "verify:contracts": "tsx scripts/verify-contracts.ts",
    "check:deployment": "tsx scripts/check-deployment.ts",
    "gen:oracle-key": "tsx scripts/gen-oracle-key.ts",
    "rotate:oracle": "tsx scripts/rotate-oracle.ts",
    "inspect:router": "tsx scripts/inspect-router-response.ts",
    "benchmark:cold-start": "tsx scripts/benchmark-cold-start.ts",
    "smoke:studio": "tsx scripts/smoke-studio-deploy.ts",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.9",
    "@eslint/js": "9.12.0",
    "@types/node": "22.7.5",
    "eslint": "9.12.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.3.3",
    "tsx": "4.19.1",
    "turbo": "2.1.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.8.1"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "1.2.1",
    "dotenv": "16.4.5",
    "ethers": "6.13.4",
    "pino": "9.5.0",
    "pino-pretty": "11.2.2",
    "zod": "3.23.8"
  }
}
